# Production environment variables for the unified Docker deployment.
# Copy to .env and fill in real values -- never commit the filled-in file.
# Local development via Aspire does not use this file: Postgres is
# provisioned automatically, and the JWT secret is supplied via
# `dotnet user-secrets` or a gitignored appsettings.Development.json.

# .NET config-style double underscore maps to nested JSON, e.g.
# Jwt__SecretKey -> { "Jwt": { "SecretKey": "..." } }

# Required. HMAC signing key for JWTs, min 32 characters. The app throws
# a startup error if this is blank or missing.
Jwt__SecretKey=

# Required. Postgres connection string used by EF Core.
ConnectionStrings__videomanager=Host=localhost;Database=videomanager;Username=postgres;Password=change-me

# Required unless IMMICH_ADMIN_PASSWORD is set (see below). Pre-existing
# Immich API key; if omitted, one is bootstrapped automatically at startup.
IMMICH_API_KEY=

# Required if IMMICH_API_KEY is omitted. Password for the Immich admin
# account used to bootstrap an API key on first run.
IMMICH_ADMIN_PASSWORD=
